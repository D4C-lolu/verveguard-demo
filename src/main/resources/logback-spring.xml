<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <conversionRule conversionWord="clr"
                    class="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex"
                    class="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>

    <property name="GREY" value="%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint}"/>
    <property name="APP" value="%clr([${springAppName:-app}]){cyan}"/>
    <property name="THREAD" value="%clr([%15.15t]){faint}"/>
    <property name="LOGGER" value="%clr(%-40.40logger{39}){cyan}"/>

    <!-- ═══════════════════════════════════════════════
         CONSOLE (coloured) — dev only
         ═══════════════════════════════════════════════ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${GREY} ${APP} ${THREAD} %clr(%-5level){ERROR=bold_red, WARN=yellow, INFO=green, DEBUG=blue,
                TRACE=faint} %clr([traceId=%X{traceId:-NO_TRACE}]){magenta} %clr([spanId=%X{spanId:-NO_SPAN}]){yellow}
                ${LOGGER} : %msg%n%wex
            </pattern>
        </encoder>
    </appender>

    <!-- ═══════════════════════════════════════════════
         CONSOLE (plain) — prod only
         ═══════════════════════════════════════════════ -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} [%15.15t] %-5level [traceId=%X{traceId:-NO_TRACE}]
                [spanId=%X{spanId:-NO_SPAN}] %-40.40logger{39} : %msg%n%wex
            </pattern>
        </encoder>
    </appender>

    <!-- ═══════════════════════════════════════════════
         PROFILES
         ═══════════════════════════════════════════════ -->

    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
    </springProfile>

    <springProfile name="local">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="docker">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <springProfile name="!(dev | prod | local | docker)">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>